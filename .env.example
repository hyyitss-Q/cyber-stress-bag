# 复制本文件为 .env，填入你的 Claude API key。

# 【必填】去 platform.claude.com 申请
ANTHROPIC_API_KEY=sk-ant-在这里粘贴你的key

# ── 下面都是可选项，不填走默认值 ───────────────────────────────
# 用哪个模型
# CYBERCAT_MODEL=claude-opus-4-8
# 单次回复最大 token
# CYBERCAT_MAX_TOKENS=2048
# 限流/过载时的自动重试次数
# CYBERCAT_MAX_RETRIES=3
# 呼出/隐藏猫的全局热键
# CYBERCAT_HOTKEY=Ctrl+Alt+C
